{
  "name": "digital-library",
  "version": "1.0.3",
  "description": "Search books through the Aladin open API and build a card gallery library in Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "aladin",
    "book",
    "library"
  ],
  "author": "HyoYoonNam",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/parser": "^8.64.0",
    "esbuild": "0.20.0",
    "eslint": "^9.39.5",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "obsidian": "latest",
    "tslib": "2.6.2",
    "typescript": "5.3.3",
    "typescript-eslint": "^8.64.0"
  }
}
